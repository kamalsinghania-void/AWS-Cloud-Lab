{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "LambdaActions",
            "Effect": "Allow",
            "Action": [
                "lambda:CreateFunction",
                "lambda:GetFunction",
                "lambda:UpdateFunctionCode",
                "lambda:DeleteFunction",
                "lambda:InvokeFunction"
            ],
            "Resource": [
                "arn:aws:lambda:*:*:function:TestLambdaFunction",
                "arn:aws:lambda:*:*:function:TestLambdaFunction:$LATEST"
            ]
        },
        {
            "Sid": "IAMActions",
            "Effect": "Allow",
            "Action": [
                "iam:CreateRole",
                "iam:DeleteRole",
                "iam:GetRole"
            ],
            "Resource": [
                "arn:aws:iam::*:role/TestLambdaRole"
            ]
        },
        {
            "Sid": "RoleAssumption",
            "Effect": "Allow",
            "Action": "iam:PassRole",
            "Resource": "arn:aws:iam::*:role/TestLambdaRole",
            "Condition": {
                "StringEquals": {
                    "iam:PassedToService": [
                        "lambda.amazonaws.com"
                    ]
                }
            }
        },
        {
            "Sid": "AttachDetachRoles",
            "Effect": "Allow",
            "Action": [
                "iam:DetachRolePolicy",
                "iam:AttachRolePolicy"
            ],
            "Resource": "arn:aws:iam::*:role/TestLambdaRole",
            "Condition": {
                "ArnEquals": {
                    "iam:PolicyARN": [
                        "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole"
                    ]
                }
            }
        },
        {
            "Sid": "S3Actions",
            "Effect": "Allow",
            "Action": [
                "s3:CreateBucket",
                "s3:GetBucketPolicy",
                "s3:PutEncryptionConfiguration",
                "s3:GetEncryptionConfiguration",
                "s3:GetBucketPublicAccessBlock",
                "s3:PutBucketPublicAccessBlock",
                "s3:PutBucketOwnershipControls",
                "s3:DeleteBucketPolicy",
                "s3:PutBucketPolicy",
                "s3:GetAccountPublicAccessBlock",
                "s3:DeleteBucket",
                "s3:GetBucketPolicyStatus",
                "s3:PutObject",
                "s3:GetObject",
                "s3:DeleteObject"
            ],
            "Resource": [
                "arn:aws:s3:::test-bucket*",
                "arn:aws:s3:::test-bucket*/*"
            ]
        },
        {
            "Sid": "OtherActions",
            "Effect": "Allow",
            "Action": [
                "access-analyzer:ValidatePolicy",
                "lambda:ListFunctions",
                "lambda:GetAccountSettings",
                "iam:ListPolicies",
                "iam:ListRoles",
                "iam:ListAttachedRolePolicies",
                "iam:ListRolePolicies",
                "iam:ListInstanceProfilesForRole",
                "iam:ListRoleTags",
                "s3:ListAllMyBuckets",
                "s3:ListBucket",
                "s3:ListBucketVersions"
            ],
            "Resource": "*"
        }
    ]
}
